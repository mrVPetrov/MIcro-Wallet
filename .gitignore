# ==========================================
# 1. Laravel Core (Стандартные правила)
# ==========================================
/vendor/
/node_modules/
/public/hot
/public/storage
/storage/*.key
/storage/logs/laravel.log
/storage/framework/views/
/storage/framework/cache/data/
/storage/framework/sessions/
.env
.env.backup
.env.php
.env.*.local
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log

# ==========================================
# 2. Docker (Специфика контейнеризации)
# ==========================================
